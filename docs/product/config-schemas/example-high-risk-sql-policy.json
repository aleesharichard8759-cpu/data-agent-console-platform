      "tenant_id": "tenant_loctek",
      "name": "Production Raw or Sensitive SQL Requires Approval",
      "description": "Production SQL accessing raw layers, sensitive columns, large results or cross-domain joins must enter ASK and Plan Mode.",
      "status": "active",
      "version": "2026.06.03",
      "owner_ids": [
        "user_security",
        "user_data_governance_owner"
      ],
      "tags": [
        "sql-gateway",
        "g4",
        "approval"
      ],
