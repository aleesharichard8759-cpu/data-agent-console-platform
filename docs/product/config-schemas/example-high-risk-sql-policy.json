      "environment_ids": [
        "env_prod"
      ],
      "data_source_ids": [
        "ds_starrocks_rma_ads_prod"
      ],
      "risk_types": [
        "NO_LIMIT",
        "SENSITIVE_COLUMN",
        "RAW_LAYER_ACCESS",
        "CROSS_DOMAIN_JOIN",
        "LARGE_RESULT_RISK"
      ],
      "decision": "ASK",
      "default_limit": 100,
      "max_limit": 1000,
      "allow_rewrite": true,
      "requires_approval": true,
      "approval_policy_id": "approval_sql_g4_prod",
      "reason": "Production SQL with raw, sensitive, large-result or cross-domain risk requires approval and audit before execution."
    },
