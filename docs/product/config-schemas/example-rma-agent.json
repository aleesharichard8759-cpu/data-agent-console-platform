  "semantic_metrics": [
    {
      "id": "metric_rma_complaint_rate",
      "tenant_id": "tenant_loctek",
      "name": "RMA Complaint Rate",
      "metric_code": "rma_complaint_rate",
      "display_name": "客诉率",
      "description": "RMA complaint rate for aggregated after-sales analysis.",
      "status": "active",
      "version": "2026.06.03",
      "owner_ids": [
        "user_rma_data_owner"
      ],
      "tags": [
        "rma",
        "complaint-rate"
      ],
      "created_at": "2026-06-03T00:00:00+08:00",
      "updated_at": "2026-06-03T00:00:00+08:00",
      "business_definition": "客诉率用于衡量问题品数量相对于销量的比例。",
      "formula": "SUM(problem_quantity) / NULLIF(SUM(sale_quantity), 0)",
      "unit": "percent",
      "aggregation": "ratio",
      "dimension_ids": [
        "dim_stat_date",
        "dim_market",
        "dim_problem_reason"
      ],
      "business_entity_ids": [
        "be_rma_after_sales"
      ],
      "data_source_id": "ds_starrocks_rma_ads_prod",
      "source_table": "ads_afs_rma_multi_dim_metric_1d",
      "source_fields": [
        "problem_quantity",
        "sale_quantity"
      ],
      "sensitivity_level": "L2",
      "owner_id": "user_rma_data_owner"
    },
    {
      "id": "metric_rma_problem_quantity",
      "tenant_id": "tenant_loctek",
      "name": "RMA Problem Quantity",
